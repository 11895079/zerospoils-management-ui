#!/usr/bin/env bash
# Pre-commit hook for Flutter project
# Runs format check and analyzer before allowing commit

set -e

echo "?? Running pre-commit checks..."

# Skip Dart/Flutter checks if no staged changes in app/
if git diff --cached --quiet -- app/; then
    echo "No staged changes in app/; skipping Dart/Flutter checks."
    exit 0
fi

# Change to app directory
cd "$(git rev-parse --show-toplevel)/app" || exit 1

# Check formatting
echo "?? Checking Dart formatting..."
if ! dart format --set-exit-if-changed .; then
    echo "? Formatting check failed. Run 'cd app && dart format .' to fix."
    exit 1
fi
echo "? Formatting check passed"

# Run analyzer
echo "?? Running Flutter analyzer..."
if ! flutter analyze --no-pub; then
    echo "? Analyzer found issues. Fix them before committing."
    exit 1
fi
echo "? Analyzer passed"

# Run tests
echo "?? Running tests..."
if ! flutter test; then
    echo "? Tests failed. Fix them before committing."
    exit 1
fi
echo "? Tests passed"

echo "? All pre-commit checks passed!"
exit 0