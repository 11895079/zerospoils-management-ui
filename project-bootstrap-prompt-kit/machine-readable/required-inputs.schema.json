{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-bootstrap.required-inputs.schema.json",
  "title": "Project Bootstrap Intake",
  "type": "object",
  "required": [
    "project",
    "docs",
    "constraints"
  ],
  "properties": {
    "project": {
      "type": "object",
      "required": [
        "name",
        "type",
        "businessObjective",
        "targetUsers"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 2 },
        "type": {
          "type": "string",
          "enum": [
            "mobile",
            "web",
            "backend",
            "data-ai",
            "saas",
            "devtool-platform",
            "other"
          ]
        },
        "businessObjective": { "type": "string", "minLength": 10 },
        "targetUsers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "docs": {
      "type": "object",
      "required": [
        "vision",
        "prd"
      ],
      "properties": {
        "vision": {
          "type": "object",
          "required": ["source", "summary"],
          "properties": {
            "source": { "type": "string" },
            "summary": { "type": "string", "minLength": 20 }
          },
          "additionalProperties": true
        },
        "prd": {
          "type": "object",
          "required": ["source", "summary"],
          "properties": {
            "source": { "type": "string" },
            "summary": { "type": "string", "minLength": 20 }
          },
          "additionalProperties": true
        },
        "milestones": {
          "type": "object",
          "properties": {
            "source": { "type": "string" },
            "summary": { "type": "string" }
          },
          "additionalProperties": true
        },
        "architectureNotes": {
          "type": "object",
          "properties": {
            "source": { "type": "string" },
            "summary": { "type": "string" }
          },
          "additionalProperties": true
        },
        "kpiBaseline": {
          "type": "object",
          "properties": {
            "source": { "type": "string" },
            "summary": { "type": "string" }
          },
          "additionalProperties": true
        },
        "releaseOps": {
          "type": "object",
          "properties": {
            "source": { "type": "string" },
            "summary": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "required": [
        "timeline",
        "budget",
        "compliance",
        "technical"
      ],
      "properties": {
        "timeline": { "type": "string" },
        "budget": { "type": "string" },
        "compliance": { "type": "string" },
        "technical": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
