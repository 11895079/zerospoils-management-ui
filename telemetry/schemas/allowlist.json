{
  "events": {
    "app_installed": {
      "allowed_properties": ["is_first_install"],
      "description": "App first launched"
    },
    "item_added": {
      "allowed_properties": [
        "item_id",
        "source",
        "entry_method",
        "camera_used",
        "category",
        "is_custom_category",
        "location",
        "quantity",
        "has_expiry",
        "has_expiry_date",
        "camera_barcode_accepted",
        "camera_expiry_accepted",
        "camera_barcode_source",
        "camera_expiry_format"
      ],
      "description": "User adds item to inventory"
    },
    "item_wasted": {
      "allowed_properties": ["category", "days_until_expiry", "waste_reason", "cost"],
      "description": "User marks item as wasted"
    },
    "reminder_opened": {
      "allowed_properties": ["item_category", "days_until_expiry"],
      "description": "User taps notification reminder"
    },
    "inventory_viewed": {
      "allowed_properties": ["filter_applied", "sort_by"],
      "description": "User opens inventory screen"
    },
    "category_created": {
      "allowed_properties": ["name", "is_custom"],
      "description": "User creates a custom category"
    },
    "category_deleted": {
      "allowed_properties": ["name", "items_affected"],
      "description": "User deletes a custom category"
    },
    "category_assigned": {
      "allowed_properties": ["category", "is_custom"],
      "description": "User assigns a category to an item"
    }
  }
}
