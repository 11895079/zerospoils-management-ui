{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "category_assigned Event",
  "description": "User assigns a category to an item",
  "type": "object",
  "required": ["id", "name", "timestamp", "app_version", "platform", "session_id", "properties"],
  "properties": {
    "id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"},
    "name": {"const": "category_assigned"},
    "timestamp": {"type": "string", "format": "date-time"},
    "app_version": {"type": "string"},
    "platform": {"type": "string", "enum": ["ios", "android"]},
    "session_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"},
    "properties": {
      "type": "object",
      "required": ["category", "is_custom"],
      "properties": {
        "category": {"type": "string", "description": "Category label shown to user"},
        "is_custom": {"type": "boolean", "description": "True when user-defined category"}
      }
    }
  }
}
