{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "category_created Event",
  "description": "User creates a custom category",
  "type": "object",
  "required": ["id", "name", "timestamp", "app_version", "platform", "session_id", "properties"],
  "properties": {
    "id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"},
    "name": {"const": "category_created"},
    "timestamp": {"type": "string", "format": "date-time"},
    "app_version": {"type": "string"},
    "platform": {"type": "string", "enum": ["ios", "android"]},
    "session_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"},
    "properties": {
      "type": "object",
      "required": ["name", "is_custom"],
      "properties": {
        "name": {"type": "string", "description": "Category name"},
        "is_custom": {"type": "boolean", "description": "True for user-defined categories"}
      }
    }
  }
}
